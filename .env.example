# Copia este archivo a .env (no subas .env a Git).
# netlify dev carga .env automáticamente.

GOOGLE_SHEETS_API_KEY=copia_aqui_tu_clave_de_google_cloud
APP_PASSCODE=define_un_codigo_secreto_para_la_app
ANTHROPIC_API_KEY=copia_aqui_tu_api_key_de_anthropic
# Recomendado para escritura robusta (ingest-mobile):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=finanzas-writer@tu-proyecto.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Opcional:
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Opcional: si lo pones, solo ese ID de spreadsheet será aceptado por la función.
# SHEETS_ALLOWED_SPREADSHEET_IDS=1Aeiav6ZIiC_o8zgqwM7qRxgFtXB3eHROW9-NtJ4GU5g
